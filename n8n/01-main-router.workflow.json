{
  "name": "MC — Main Router",
  "nodes": [
    {
      "id": "a1b2c3d4-0001",
      "name": "Action Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "mission-action",
        "responseMode": "immediatelyWithoutBody",
        "options": {}
      }
    },
    {
      "id": "a1b2c3d4-0002",
      "name": "Validate Secret",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "cond1",
              "leftValue": "={{ $json.headers['x-mission-secret'] }}",
              "rightValue": "={{ $env.MISSION_CONTROL_WEBHOOK_SECRET }}",
              "operator": { "type": "string", "operation": "equals" }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "a1b2c3d4-0003",
      "name": "Route by Type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [680, 220],
      "parameters": {
        "mode": "expression",
        "output": "input",
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": true },
                "conditions": [{ "leftValue": "={{ $json.body.action.type }}", "rightValue": "GMAIL_SEND", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "gmail_send"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true },
                "conditions": [{ "leftValue": "={{ $json.body.action.type }}", "rightValue": "GMAIL_REPLY", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "gmail_reply"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true },
                "conditions": [{ "leftValue": "={{ $json.body.action.type }}", "rightValue": "CALENDAR_CREATE", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "calendar_create"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true },
                "conditions": [{ "leftValue": "={{ $json.body.action.type }}", "rightValue": "CALENDAR_UPDATE", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "calendar_update"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true },
                "conditions": [{ "leftValue": "={{ $json.body.action.type }}", "rightValue": "DRIVE_UPLOAD", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "drive_upload"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true },
                "conditions": [{ "leftValue": "={{ $json.body.action.type }}", "rightValue": "DRIVE_SEARCH", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "drive_search"
            }
          ]
        },
        "fallbackOutput": "extra"
      }
    },
    {
      "id": "a1b2c3d4-0010",
      "name": "Gmail Workflow",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [900, 100],
      "parameters": {
        "workflowId": { "__rl": true, "value": "GMAIL_WORKFLOW_ID", "mode": "id" },
        "source": "database",
        "options": { "waitForSubWorkflow": true }
      }
    },
    {
      "id": "a1b2c3d4-0011",
