      "position": [680, 420],
      "parameters": {
        "jsCode": "console.log('Unauthorized request to mission-action webhook'); return [];"
      }
    }
  ],
  "connections": {
    "Action Webhook": {
      "main": [[ { "node": "Validate Secret", "type": "main", "index": 0 } ]]
    },
    "Validate Secret": {
      "main": [
        [ { "node": "Route by Type", "type": "main", "index": 0 } ],
